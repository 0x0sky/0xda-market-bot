PORT=10000
RACK_ENV=production

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me

# Keep the production bot pointed at the existing Render core until the VPS
# core has passed its own health checks and the API cutover is approved.
MARKET_API_URL=https://zeroxda-market.onrender.com
MARKET_API_TOKEN=replace-me

# Keep disabled during parallel smoke testing. Enable only immediately before
# switching the Telegram webhook to https://app.nilx.one/telegram/webhook.
REGISTER_TELEGRAM_WEBHOOK=0
PUBLIC_URL=https://app.nilx.one
