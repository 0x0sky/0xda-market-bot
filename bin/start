#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/zero_x_da/market_client_bot/telegram_api"

public_url = ENV.fetch("PUBLIC_URL").delete_suffix("/")
telegram = ZeroXDA::MarketClientBot::TelegramAPI.new(
  token: ENV.fetch("TELEGRAM_BOT_TOKEN")
)
telegram.set_webhook(
  url: "#{public_url}/telegram/webhook",
  secret_token: ENV.fetch("TELEGRAM_WEBHOOK_SECRET")
)

exec("bundle", "exec", "puma", "-C", "config/puma.rb", "config.ru")
